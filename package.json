{
  "name": "pi-claude-powerline",
  "version": "0.1.0",
  "description": "Pi extension that adds Claude Powerline-inspired themes",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "extension",
    "theme",
    "claude-powerline"
  ],
  "license": "MIT",
  "files": [
    "index.ts",
    "footer-session-name.ts",
    "footer-width.ts",
    "ansi-truncation.ts",
    "context-glyph.ts",
    "context-metrics.ts",
    "powerline-glyphs.ts",
    "tests/*.test.ts",
    "themes/*.json",
    "README.md"
  ],
  "scripts": {
    "test": "node --experimental-strip-types --test ./tests/*.test.ts"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ],
    "themes": [
      "./themes"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-tui": "*"
  }
}
